# ============================================================
# ENVIRONMENT VARIABLES — COPY THIS FILE TO .env AND FILL IN
# ============================================================
# Never commit .env — only commit this .env.example file

# ── Neo4j Aura ──────────────────────────────────────────────
NEO4J_URI=neo4j+s://<your-instance-id>.databases.neo4j.io
NEO4J_USER=<your-username>
NEO4J_USERNAME=<your-username>
NEO4J_PASSWORD=<your-password>
NEO4J_DATABASE=<your-database-name>
AURA_INSTANCEID=<your-instance-id>
AURA_INSTANCENAME=<your-instance-name>

# ── AWS Configuration ────────────────────────────────────────
AWS_ACCOUNT_ID=<your-aws-account-id>
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# ── AWS Neptune ──────────────────────────────────────────────
NEPTUNE_CLUSTER_ENDPOINT=<your-cluster-id>.cluster-<xxx>.us-west-2.neptune.amazonaws.com
NEPTUNE_PORT=8182
NEPTUNE_GREMLIN_URL=wss://<your-cluster-endpoint>:8182/gremlin
NEPTUNE_SPARQL_URL=https://<your-cluster-endpoint>:8182/sparql

# ── AWS OpenSearch ───────────────────────────────────────────
OPENSEARCH_ENDPOINT=https://search-<domain-name>-<hash>.us-west-2.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=<your-opensearch-password>
OPENSEARCH_INDEX=drugs

# ── AWS Strands / Bedrock ────────────────────────────────────
BEDROCK_REGION=us-west-2
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Anthropic Claude (direct) ────────────────────────────────
CLAUDE_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
