# ============================================================
# ENVIRONMENT VARIABLES — COPY THIS FILE TO .env AND FILL IN
# ============================================================
# Never commit .env — only commit this .env.example file

# ── Neo4j Aura ──────────────────────────────────────────────
NEO4J_URI=neo4j+s://<your-instance-id>.databases.neo4j.io
NEO4J_USER=<your-username>
NEO4J_USERNAME=<your-username>
NEO4J_PASSWORD=<your-password>
NEO4J_DATABASE=<your-database-name>
AURA_INSTANCEID=<your-instance-id>
AURA_INSTANCENAME=<your-instance-name>

# ── AWS Configuration ────────────────────────────────────────
AWS_ACCOUNT_ID=<your-aws-account-id>
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# ── AWS Neptune DB ───────────────────────────────────────────
NEPTUNE_DB_ENDPOINT=<your-cluster-id>.cluster-<xxx>.us-west-2.neptune.amazonaws.com
NEPTUNE_DB_PORT=8182

# ── AWS Neptune Analytics ────────────────────────────────────
NEPTUNE_ANALYTICS_ENDPOINT=<graph-id>.us-west-2.neptune-graph.amazonaws.com
NEPTUNE_ANALYTICS_GRAPH_ID=<graph-id>

# ── AWS OpenSearch ───────────────────────────────────────────
OPENSEARCH_DOMAIN=graphrag-opensearch
OPENSEARCH_USER=admin
OPENSEARCH_PASS=<your-opensearch-password>

# ── AWS Strands / Bedrock ────────────────────────────────────
BEDROCK_REGION=us-west-2
